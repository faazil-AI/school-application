# Native PostgreSQL — see docs/POSTGRESQL_SETUP.md
DATABASE_URL=postgresql://madrasa_admin:YOUR_PASSWORD@localhost:5432/madrasa

# Required — generate with: openssl rand -base64 32
AUTH_SECRET=
AUTH_URL=http://localhost:3000

# Google Sign-In (recommended for production)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_DEFAULT_ORG_NAME=Madrasa

# First admin created by db:seed (Email OTP + Google Sign-In)
SEED_ADMIN_EMAIL=admin2721@gmail.com
SEED_ADMIN_NAME=Madrasa Admin

# Production: leave false / unset. Development: true to seed @madrasa.local accounts
SEED_DEV_USERS=false

# Development only — never true in production
ALLOW_DEV_LOGIN=false
SKIP_OTP_ENFORCEMENT=false

# Email OTP — Resend (recommended for production)
RESEND_API_KEY=
RESEND_FROM=notifications@yourdomain.com

# Email OTP — SMTP fallback (optional if using Resend)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# Dev OTP override (development only, with ALLOW_DEV_LOGIN=true)
OTP_DEV_CODE=
